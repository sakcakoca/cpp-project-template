# Conan 2 profile: Windows + MSYS2 Clang
# Adjust compiler.version to match your MSYS2 Clang version.
# Run "clang --version" in an MSYS2 terminal to check.

[settings]
os=Windows
arch=x86_64
compiler=clang
compiler.version=22
compiler.cppstd=23
compiler.libcxx=libc++
build_type=Release

[conf]
tools.build:compiler_executables={"c": "clang", "cpp": "clang++"}
tools.cmake.cmaketoolchain:generator=Ninja
