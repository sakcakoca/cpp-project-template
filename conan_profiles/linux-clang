# Conan 2 profile: Linux + Clang
# Adjust compiler.version to match your installed Clang version.
# Run "clang --version" to check.

[settings]
os=Linux
arch=x86_64
compiler=clang
compiler.version=22
compiler.cppstd=26
compiler.libcxx=libstdc++11
build_type=Release

[conf]
tools.build:compiler_executables={"c": "clang", "cpp": "clang++"}
