# Conan 2 profile: macOS + Homebrew GCC
# Adjust compiler.version and executable paths to match your Homebrew GCC.
# Run "brew info gcc" and "/opt/homebrew/bin/gcc-15 --version" to check.
# For Intel Macs, change arch to x86_64 and paths to /usr/local/bin/.

[settings]
os=Macos
arch=armv8
compiler=gcc
compiler.version=15
compiler.cppstd=23
compiler.libcxx=libstdc++11
build_type=Release

[conf]
tools.apple:sdk_path=/Library/Developer/CommandLineTools/SDKs/MacOSX15.sdk
tools.build:compiler_executables={'c': '/opt/homebrew/bin/gcc-15', 'cpp': '/opt/homebrew/bin/g++-15'}