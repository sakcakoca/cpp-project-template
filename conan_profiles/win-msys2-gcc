# Conan 2 profile: Windows + MSYS2 GCC
# Adjust compiler.version to match your MSYS2 GCC version.
# Run "gcc --version" in an MSYS2 terminal to check.

[settings]
os=Windows
arch=x86_64
compiler=gcc
compiler.version=15
compiler.cppstd=23
compiler.libcxx=libstdc++11
build_type=Release

[conf]
tools.build:compiler_executables={"c": "gcc", "cpp": "g++"}
tools.cmake.cmaketoolchain:generator=Ninja
