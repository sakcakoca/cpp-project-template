# Conan 2 profile: Linux + GCC
# Adjust compiler.version to match your installed GCC version.
# Run "gcc --version" to check.

[settings]
os=Linux
arch=x86_64
compiler=gcc
compiler.version=15
compiler.cppstd=23
compiler.libcxx=libstdc++11
build_type=Release

[conf]
tools.build:compiler_executables={"c": "gcc", "cpp": "g++"}
