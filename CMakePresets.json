{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "description": "Shared settings: Ninja generator, build dir, compile-commands, Conan env",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/${presetName}/install",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      },
      "environment": {
        "CONAN_HOST_PROFILE": "default",
        "CONAN_BUILD_PROFILE": "default",
        "CONAN_SETTING_COMPILER_CPPSTD": "23",
        "CONAN_CONF_CMAKE_TOOLCHAIN_GENERATOR": "Ninja"
      }
    },
    { "name": "cfg-debug", "hidden": true, "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" } },
    { "name": "cfg-release", "hidden": true, "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" } },
    { "name": "cfg-relwithdebinfo", "hidden": true, "cacheVariables": { "CMAKE_BUILD_TYPE": "RelWithDebInfo" } },
    { "name": "san-asan", "hidden": true, "cacheVariables": { "ENABLE_SANITIZER_ADDRESS":"ON", "ENABLE_SANITIZER_UNDEFINED":"ON" } },
    { "name": "san-tsan", "hidden": true, "cacheVariables": { "ENABLE_SANITIZER_THREAD": "ON" } },
    { "name": "san-lsan", "hidden": true, "cacheVariables": { "ENABLE_SANITIZER_LEAK": "ON" } },
    { "name": "san-msan", "hidden": true, "cacheVariables": { "ENABLE_SANITIZER_MEMORY": "ON" } },

    {
      "name": "linux-gcc",
      "hidden": true,
      "inherits": "base",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      },
      "environment": {
        "CONAN_HOST_PROFILE": "${sourceDir}/conan_profiles/linux",
        "CONAN_SETTING_COMPILER": "gcc",
        "CONAN_SETTING_COMPILER_VERSION": "15",
        "CONAN_SETTING_COMPILER_LIBCXX": "libstdc++11",
        "CONAN_CONF_COMPILER_EXECUTABLES": "{\"c\": \"gcc\", \"cpp\": \"g++\"}"
      }
    },
    {
      "name": "linux-clang",
      "hidden": true,
      "inherits": "base",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      },
      "environment": {
        "CONAN_HOST_PROFILE": "${sourceDir}/conan_profiles/linux",
        "CONAN_SETTING_COMPILER": "clang",
        "CONAN_SETTING_COMPILER_VERSION": "22",
        "CONAN_SETTING_COMPILER_LIBCXX": "libstdc++11",
        "CONAN_CONF_COMPILER_EXECUTABLES": "{\"c\": \"clang\", \"cpp\": \"clang++\"}"
      }
    },
    {
      "name": "macos-gcc",
      "hidden": true,
      "inherits": "base",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "/opt/homebrew/bin/gcc-15",
        "CMAKE_CXX_COMPILER": "/opt/homebrew/bin/g++-15",
        "CMAKE_OSX_SYSROOT": "/Library/Developer/CommandLineTools/SDKs/MacOSX15.sdk"
      },
      "environment": {
        "CONAN_HOST_PROFILE": "${sourceDir}/conan_profiles/macos",
        "CONAN_SETTING_COMPILER": "gcc",
        "CONAN_SETTING_COMPILER_VERSION": "15",
        "CONAN_SETTING_COMPILER_LIBCXX": "libstdc++11",
        "CONAN_CONF_COMPILER_EXECUTABLES": "{\"c\": \"/opt/homebrew/bin/gcc-15\", \"cpp\": \"/opt/homebrew/bin/g++-15\"}",
        "CONAN_CONF_APPLE_SDK_PATH": "/Library/Developer/CommandLineTools/SDKs/MacOSX15.sdk"
      }
    },
    {
      "name": "macos-clang",
      "hidden": true,
      "inherits": "base",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "/opt/homebrew/opt/llvm/bin/clang",
        "CMAKE_CXX_COMPILER": "/opt/homebrew/opt/llvm/bin/clang++"
      },
      "environment": {
        "CONAN_HOST_PROFILE": "${sourceDir}/conan_profiles/macos",
        "CONAN_SETTING_COMPILER": "clang",
        "CONAN_SETTING_COMPILER_VERSION": "22",
        "CONAN_SETTING_COMPILER_LIBCXX": "libc++",
        "CONAN_CONF_COMPILER_EXECUTABLES": "{\"c\": \"/opt/homebrew/opt/llvm/bin/clang\", \"cpp\": \"/opt/homebrew/opt/llvm/bin/clang++\"}"
      }
    },
    {
      "name": "win-msys2-gcc",
      "hidden": true,
      "inherits": "base",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      },
      "environment": {
        "CONAN_HOST_PROFILE": "${sourceDir}/conan_profiles/win-msys2",
        "CONAN_SETTING_COMPILER": "gcc",
        "CONAN_SETTING_COMPILER_VERSION": "15",
        "CONAN_SETTING_COMPILER_LIBCXX": "libstdc++11",
        "CONAN_CONF_COMPILER_EXECUTABLES": "{\"c\": \"gcc\", \"cpp\": \"g++\"}"
      }
    },
    {
      "name": "win-msys2-clang",
      "hidden": true,
      "inherits": "base",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      },
      "environment": {
        "CONAN_HOST_PROFILE": "${sourceDir}/conan_profiles/win-msys2",
        "CONAN_SETTING_COMPILER": "clang",
        "CONAN_SETTING_COMPILER_VERSION": "22",
        "CONAN_SETTING_COMPILER_LIBCXX": "libc++",
        "CONAN_CONF_COMPILER_EXECUTABLES": "{\"c\": \"clang\", \"cpp\": \"clang++\"}"
      }
    },
    {
      "name": "win-msys2-clang-libstdc++",
      "hidden": true,
      "inherits": "win-msys2-clang",
      "environment": {
        "CONAN_SETTING_COMPILER_LIBCXX": "libstdc++11"
      }
    },
    {
      "name": "win-msvc",
      "hidden": true,
      "inherits": "base",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" },
      "architecture": { "value": "x64", "strategy": "external" },
      "toolset": { "value": "host=x64", "strategy": "external" },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_COMPILER": "cl",
        "CMAKE_LINKER": "link"
      },
      "environment": {
        "CONAN_HOST_PROFILE": "${sourceDir}/conan_profiles/win-msvc",
        "CONAN_SETTING_COMPILER": "msvc",
        "CONAN_SETTING_COMPILER_VERSION": "194",
        "CONAN_SETTING_COMPILER_RUNTIME": "dynamic",
        "CONAN_CONF_COMPILER_EXECUTABLES": "{\"c\": \"cl\", \"cpp\": \"cl\"}"
      }
    },
    { "name": "linux-gcc-debug", "displayName": "Linux GCC Debug", "inherits": ["linux-gcc", "cfg-debug"] },
    { "name": "linux-gcc-release", "displayName": "Linux GCC Release", "inherits": ["linux-gcc", "cfg-release"] },
    { "name": "linux-gcc-relwithdebinfo", "displayName": "Linux GCC RelWithDebInfo", "inherits": ["linux-gcc", "cfg-relwithdebinfo"] },
    { "name": "linux-clang-debug", "displayName": "Linux Clang Debug", "inherits": ["linux-clang", "cfg-debug"] },
    { "name": "linux-clang-release", "displayName": "Linux Clang Release", "inherits": ["linux-clang", "cfg-release"] },
    { "name": "linux-clang-relwithdebinfo", "displayName": "Linux Clang RelWithDebInfo", "inherits": ["linux-clang", "cfg-relwithdebinfo"] },
    { "name": "macos-gcc-debug", "displayName": "macOS GCC Debug", "inherits": ["macos-gcc", "cfg-debug"] },
    { "name": "macos-gcc-release", "displayName": "macOS GCC Release", "inherits": ["macos-gcc", "cfg-release"] },
    { "name": "macos-gcc-relwithdebinfo", "displayName": "macOS GCC RelWithDebInfo", "inherits": ["macos-gcc", "cfg-relwithdebinfo"] },
    { "name": "macos-clang-debug", "displayName": "macOS Clang Debug", "inherits": ["macos-clang", "cfg-debug"] },
    { "name": "macos-clang-release", "displayName": "macOS Clang Release", "inherits": ["macos-clang", "cfg-release"] },
    { "name": "macos-clang-relwithdebinfo", "displayName": "macOS Clang RelWithDebInfo", "inherits": ["macos-clang", "cfg-relwithdebinfo"] },
    { "name": "win-msys2-gcc-debug", "displayName": "Win MSYS2 GCC Debug", "inherits": ["win-msys2-gcc", "cfg-debug"] },
    { "name": "win-msys2-gcc-release", "displayName": "Win MSYS2 GCC Release", "inherits": ["win-msys2-gcc", "cfg-release"] },
    { "name": "win-msys2-gcc-relwithdebinfo", "displayName": "Win MSYS2 GCC RelWithDebInfo", "inherits": ["win-msys2-gcc", "cfg-relwithdebinfo"] },
    { "name": "win-msys2-clang-libstdc++-debug", "displayName": "Win MSYS2 Clang with libstdc++ Debug", "inherits": ["win-msys2-clang-libstdc++", "cfg-debug"] },
    { "name": "win-msys2-clang-libstdc++-release", "displayName": "Win MSYS2 Clang with libstdc++ Release", "inherits": ["win-msys2-clang-libstdc++", "cfg-release"] },
    { "name": "win-msys2-clang-libstdc++-relwithdebinfo", "displayName": "Win MSYS2 Clang with libstdc++ RelWithDebInfo", "inherits": ["win-msys2-clang-libstdc++", "cfg-relwithdebinfo"] },
    { "name": "win-msys2-clang-debug", "displayName": "Win MSYS2 Clang Debug", "inherits": ["win-msys2-clang", "cfg-debug"] },
    { "name": "win-msys2-clang-release", "displayName": "Win MSYS2 Clang Release", "inherits": ["win-msys2-clang", "cfg-release"] },
    { "name": "win-msys2-clang-relwithdebinfo", "displayName": "Win MSYS2 Clang RelWithDebInfo", "inherits": ["win-msys2-clang", "cfg-relwithdebinfo"] },
    { "name": "win-msvc-debug", "displayName": "Win MSVC Debug", "inherits": ["win-msvc", "cfg-debug"] },
    { "name": "win-msvc-release", "displayName": "Win MSVC Release", "inherits": ["win-msvc", "cfg-release"] },
    { "name": "win-msvc-relwithdebinfo", "displayName": "Win MSVC RelWithDebInfo", "inherits": ["win-msvc", "cfg-relwithdebinfo"] },
    { "name": "linux-gcc-debug-asan", "displayName": "Linux GCC Debug + ASan/UBSan", "inherits": ["linux-gcc-debug", "san-asan"] },
    { "name": "linux-gcc-debug-tsan", "displayName": "Linux GCC Debug + TSan", "inherits": ["linux-gcc-debug", "san-tsan"] },
    { "name": "linux-clang-debug-asan", "displayName": "Linux Clang Debug + ASan/UBSan", "inherits": ["linux-clang-debug", "san-asan"] },
    { "name": "linux-clang-debug-tsan", "displayName": "Linux Clang Debug + TSan", "inherits": ["linux-clang-debug", "san-tsan"] },
    {
      "name": "linux-clang-debug-msan",
      "displayName": "Linux Clang Debug + MSan (libc++)",
      "inherits": ["linux-clang-debug", "san-msan"],
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "-stdlib=libc++",
        "CMAKE_EXE_LINKER_FLAGS": "-stdlib=libc++",
        "CMAKE_SHARED_LINKER_FLAGS": "-stdlib=libc++"
      },
      "environment": {
        "CONAN_SETTING_COMPILER_LIBCXX": "libc++"
      }
    },
    { "name": "linux-gcc-debug-lsan", "displayName": "Linux GCC Debug + LSan", "inherits": ["linux-gcc-debug", "san-lsan"] },
    { "name": "linux-clang-debug-lsan", "displayName": "Linux Clang Debug + LSan", "inherits": ["linux-clang-debug", "san-lsan"] },
    { "name": "macos-clang-debug-asan", "displayName": "macOS Clang Debug + ASan/UBSan", "inherits": ["macos-clang-debug", "san-asan"] },
    { "name": "macos-clang-debug-tsan", "displayName": "macOS Clang Debug + TSan", "inherits": ["macos-clang-debug", "san-tsan"] },
    { "name": "win-msys2-clang-debug-asan", "displayName": "Win MSYS2 Clang Debug + ASan", "inherits": ["win-msys2-clang-debug", "san-asan"] },
    { "name": "win-msvc-debug-asan", "displayName": "Win MSVC Debug + ASan", "inherits": ["win-msvc-debug", "san-asan"] }
  ],
  "buildPresets": [
    { "name": "linux-gcc-debug", "configurePreset": "linux-gcc-debug" },
    { "name": "linux-gcc-release", "configurePreset": "linux-gcc-release" },
    { "name": "linux-gcc-relwithdebinfo", "configurePreset": "linux-gcc-relwithdebinfo" },
    { "name": "linux-clang-debug", "configurePreset": "linux-clang-debug" },
    { "name": "linux-clang-release", "configurePreset": "linux-clang-release" },
    { "name": "linux-clang-relwithdebinfo", "configurePreset": "linux-clang-relwithdebinfo" },
    { "name": "macos-gcc-debug", "configurePreset": "macos-gcc-debug" },
    { "name": "macos-gcc-release", "configurePreset": "macos-gcc-release" },
    { "name": "macos-gcc-relwithdebinfo", "configurePreset": "macos-gcc-relwithdebinfo" },
    { "name": "macos-clang-debug", "configurePreset": "macos-clang-debug" },
    { "name": "macos-clang-release", "configurePreset": "macos-clang-release" },
    { "name": "macos-clang-relwithdebinfo", "configurePreset": "macos-clang-relwithdebinfo" },
    { "name": "win-msys2-gcc-debug", "configurePreset": "win-msys2-gcc-debug" },
    { "name": "win-msys2-gcc-release", "configurePreset": "win-msys2-gcc-release" },
    { "name": "win-msys2-gcc-relwithdebinfo", "configurePreset": "win-msys2-gcc-relwithdebinfo" },
    { "name": "win-msys2-clang-libstdc++-debug", "configurePreset": "win-msys2-clang-libstdc++-debug" },
    { "name": "win-msys2-clang-libstdc++-release", "configurePreset": "win-msys2-clang-libstdc++-release" },
    { "name": "win-msys2-clang-libstdc++-relwithdebinfo", "configurePreset": "win-msys2-clang-libstdc++-relwithdebinfo" },
    { "name": "win-msys2-clang-debug", "configurePreset": "win-msys2-clang-debug" },
    { "name": "win-msys2-clang-release", "configurePreset": "win-msys2-clang-release" },
    { "name": "win-msys2-clang-relwithdebinfo", "configurePreset": "win-msys2-clang-relwithdebinfo" },
    { "name": "win-msvc-debug", "configurePreset": "win-msvc-debug" },
    { "name": "win-msvc-release", "configurePreset": "win-msvc-release" },
    { "name": "win-msvc-relwithdebinfo", "configurePreset": "win-msvc-relwithdebinfo" },
    { "name": "linux-gcc-debug-asan", "configurePreset": "linux-gcc-debug-asan" },
    { "name": "linux-gcc-debug-tsan", "configurePreset": "linux-gcc-debug-tsan" },
    { "name": "linux-clang-debug-asan", "configurePreset": "linux-clang-debug-asan" },
    { "name": "linux-clang-debug-tsan", "configurePreset": "linux-clang-debug-tsan" },
    { "name": "linux-clang-debug-msan", "configurePreset": "linux-clang-debug-msan" },
    { "name": "linux-gcc-debug-lsan", "configurePreset": "linux-gcc-debug-lsan" },
    { "name": "linux-clang-debug-lsan", "configurePreset": "linux-clang-debug-lsan" },
    { "name": "macos-clang-debug-asan", "configurePreset": "macos-clang-debug-asan" },
    { "name": "macos-clang-debug-tsan", "configurePreset": "macos-clang-debug-tsan" },
